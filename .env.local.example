# Required — model provider for the server-side extractor/phraser
# Use one provider. The app never calls AI APIs from the browser.
OPENAI_API_KEY=sk-...
# NVIDIA_API_KEY=...
# GITHUB_TOKEN=...

# Optional — model override
LLM_MODEL=gpt-4o-mini

# Optional — facilities API uses mock data without this
GOOGLE_PLACES_API_KEY=AIza...

# Recommended in production — protects the /metrics dashboard
METRICS_KEY=choose-a-long-random-string

# Trial/eval bypass key. Set in staging only; do not expose publicly.
TRIAL_KEY=carevo-trials-x7k2

# Optional — CMS Marketplace API (developer.cms.gov/marketplace-api): ACA plan
# data, out-of-pocket estimates, Medicaid/CHIP eligibility for uninsured users.
# Free key, CMS auto-rotates every 60 days by email. Feature hides without it.
MARKETPLACE_API_KEY=

# Recursive Experience Engine telemetry.
# Enable only after the endpoint writes to encrypted PostgreSQL.
REE_TELEMETRY_ENABLED=0
REE_TELEMETRY_ENDPOINT=
REE_TELEMETRY_SECRET=
